# کلید OpenAI شما — این فایل را به .env کپی کنید و مقدارها را پر کنید.
# ⚠️ .env را هرگز در Git کامیت نکنید (در .gitignore هست).
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# دامنه‌هایی که اجازهٔ فراخوانی دارند (فرانت‌اند)، با کاما جدا کنید. * = همه (فقط برای تست).
CORS_ORIGINS=*

# رمز پنل ادمین (/admin) — برای واردکردن کلید OpenAI از مرورگر
ADMIN_PASSWORD=یک-رمز-قوی-بگذار

# اختیاری: درگاه سازگار با OpenAI (مثلاً AI Gateway پرسیت). خالی = خود OpenAI
OPENAI_BASE_URL=
